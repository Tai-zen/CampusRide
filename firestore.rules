rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (Default-Deny Catch-All)
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable global safety and identity validation primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : 'none';
    }

    function isDriver() {
      return isSignedIn() && getUserRole() == 'driver';
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }

    // Entity validation functions
    function isValidUserProfile(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.role is string && (data.role == 'student' || data.role == 'driver' || data.role == 'admin') &&
             (!('major' in data) || (data.major is string && data.major.size() <= 100)) &&
             (!('idNumber' in data) || (data.idNumber is string && data.idNumber.size() <= 50)) &&
             (!('enrolledTerm' in data) || (data.enrolledTerm is string && data.enrolledTerm.size() <= 100)) &&
             (!('avatar' in data) || (data.avatar is string && data.avatar.size() <= 1000)) &&
             (!('vehicle' in data) || (data.vehicle is string && data.vehicle.size() <= 200)) &&
             (!('status' in data) || (data.status is string && (data.status == 'On Trip' || data.status == 'Idle' || data.status == 'Break' || data.status == 'Offline'))) &&
             (!('bankName' in data) || (data.bankName is string && data.bankName.size() <= 100)) &&
             (!('bankAccountNumber' in data) || (data.bankAccountNumber is string && data.bankAccountNumber.size() <= 20)) &&
             (!('bankAccountName' in data) || (data.bankAccountName is string && data.bankAccountName.size() <= 100)) &&
             (!('walletBalance' in data) || (data.walletBalance is number)) &&
             (!('tripsThisWeek' in data) || (data.tripsThisWeek is number)) &&
             (!('carpoolRides' in data) || (data.carpoolRides is number)) &&
             (!('savedThisMonth' in data) || (data.savedThisMonth is number)) &&
             (!('rating' in data) || (data.rating is number)) &&
             (!('ratingsCount' in data) || (data.ratingsCount is number)) &&
             (!('todayEarnings' in data) || (data.todayEarnings is number)) &&
             (!('completedTripsCount' in data) || (data.completedTripsCount is number)) &&
             (!('hoursOnline' in data) || (data.hoursOnline is number)) &&
             (!('isVerified' in data) || (data.isVerified is bool)) &&
             (!('isApproved' in data) || (data.isApproved is bool)) &&
             (!('carBrand' in data) || (data.carBrand is string && data.carBrand.size() <= 100)) &&
             (!('plateNumber' in data) || (data.plateNumber is string && data.plateNumber.size() <= 30)) &&
             (!('carType' in data) || (data.carType is string && (data.carType == 'car' || data.carType == 'keke' || data.carType == 'shuttle'))) &&
             (!('vehicleId' in data) || (data.vehicleId is string && data.vehicleId.size() <= 100)) &&
             (!('createdAt' in data) || (data.createdAt is string && data.createdAt.size() <= 100)) &&
             (!('adminComments' in data) || (data.adminComments is string && data.adminComments.size() <= 500) || data.adminComments == null) &&
             (!('declined' in data) || (data.declined is bool)) &&
             (!('declineReason' in data) || (data.declineReason is string && data.declineReason.size() <= 500));
    }

    function isValidTransaction(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.description is string && data.description.size() <= 200 &&
             data.amount is number &&
             data.type is string && (data.type == 'charge' || data.type == 'reload') &&
             data.status is string && (data.status == 'Completed' || data.status == 'Pending' || data.status == 'Canceled');
    }

    function isValidNotification(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 100 &&
             data.message is string && data.message.size() <= 500 &&
             data.isRead is bool &&
             data.type is string && (data.type == 'info' || data.type == 'success' || data.type == 'receipt' || data.type == 'alert' || data.type == 'warning') &&
             (!('date' in data) || (data.date is string && data.date.size() <= 50)) &&
             (!('time' in data) || (data.time is string && data.time.size() <= 50)) &&
             (!('timestamp' in data) || (data.timestamp is string && data.timestamp.size() <= 100));
    }

    function isValidReview(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.passengerName is string && data.passengerName.size() <= 100 &&
             data.rating is number &&
             data.comment is string && data.comment.size() <= 500 &&
             (!('passengerAvatar' in data) || (data.passengerAvatar is string && data.passengerAvatar.size() <= 1000)) &&
             (!('time' in data) || (data.time is string && data.time.size() <= 50)) &&
             (!('date' in data) || (data.date is string && data.date.size() <= 50)) &&
             (!('createdAt' in data) || (data.createdAt is number));
    }

    function isValidSchool(data) {
      return data.logoImage is string && data.logoImage.size() <= 1000 &&
             (!('updatedAt' in data) || (data.updatedAt is number));
    }

    function isValidRideRequest(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.passengerId is string && data.passengerId.size() <= 128 &&
             data.pickup is string && data.pickup.size() <= 200 &&
             data.dropoff is string && data.dropoff.size() <= 200 &&
             data.status is string && (data.status == 'requested' || data.status == 'accepted' || data.status == 'arriving' || data.status == 'in_transit' || data.status == 'completed' || data.status == 'canceled' || data.status == 'pending_driver_acceptance') &&
             data.cost is number &&
             (!('passengerName' in data) || (data.passengerName is string && data.passengerName.size() <= 100)) &&
             (!('passengerAvatar' in data) || (data.passengerAvatar is string && data.passengerAvatar.size() <= 1000)) &&
             (!('passengerRating' in data) || (data.passengerRating is number)) &&
             (!('passengerType' in data) || (data.passengerType is string && (data.passengerType == 'Student' || data.passengerType == 'Staff' || data.passengerType == 'Faculty'))) &&
             (!('vehicleType' in data) || (data.vehicleType is string && (data.vehicleType == 'Car' || data.vehicleType == 'Keke' || data.vehicleType == 'Shuttle'))) &&
             (!('verifyPeer' in data) || (data.verifyPeer is bool)) &&
             (!('driverId' in data) || (data.driverId is string && data.driverId.size() <= 128) || data.driverId == null) &&
             (!('driverName' in data) || (data.driverName is string && data.driverName.size() <= 100) || data.driverName == null) &&
             (!('driverAvatar' in data) || (data.driverAvatar is string && data.driverAvatar.size() <= 1000) || data.driverAvatar == null) &&
             (!('driverVehicle' in data) || (data.driverVehicle is string && data.driverVehicle.size() <= 200) || data.driverVehicle == null) &&
             (!('driverRating' in data) || (data.driverRating is number) || data.driverRating == null) &&
             (!('driverPlateNumber' in data) || (data.driverPlateNumber is string && data.driverPlateNumber.size() <= 50) || data.driverPlateNumber == null) &&
             (!('driverBankName' in data) || (data.driverBankName is string && data.driverBankName.size() <= 100) || data.driverBankName == null) &&
             (!('driverBankAccountNumber' in data) || (data.driverBankAccountNumber is string && data.driverBankAccountNumber.size() <= 20) || data.driverBankAccountNumber == null) &&
             (!('driverBankAccountName' in data) || (data.driverBankAccountName is string && data.driverBankAccountName.size() <= 100) || data.driverBankAccountName == null) &&
             (!('etaMinutes' in data) || (data.etaMinutes is number)) &&
             (!('date' in data) || (data.date is string && data.date.size() <= 50)) &&
             (!('time' in data) || (data.time is string && data.time.size() <= 50)) &&
             (!('createdAt' in data) || (data.createdAt is number)) &&
             (!('paymentMethod' in data) || (data.paymentMethod is string && (data.paymentMethod == 'cash' || data.paymentMethod == 'transfer' || data.paymentMethod == 'wallet'))) &&
             (!('paymentConfirmedByRider' in data) || (data.paymentConfirmedByRider is bool)) &&
             (!('paymentValidatedByDriver' in data) || (data.paymentValidatedByDriver is bool)) &&
             (!('riderPaid' in data) || (data.riderPaid is bool)) &&
             (!('passengerRated' in data) || (data.passengerRated is bool)) &&
             (!('driverConcluded' in data) || (data.driverConcluded is bool)) &&
             (!('driverCredited' in data) || (data.driverCredited is bool)) &&
             (!('pickupId' in data) || (data.pickupId is string && data.pickupId.size() <= 100)) &&
             (!('dropoffId' in data) || (data.dropoffId is string && data.dropoffId.size() <= 100)) &&
             (!('fare' in data) || (data.fare is number)) &&
             (!('mode' in data) || (data.mode is string && data.mode.size() <= 50));
    }

    function isValidPendingDriver(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             (!('carBrand' in data) || (data.carBrand is string && data.carBrand.size() <= 100)) &&
             (!('carType' in data) || (data.carType is string && (data.carType == 'car' || data.carType == 'keke' || data.carType == 'shuttle'))) &&
             (!('plateNumber' in data) || (data.plateNumber is string && data.plateNumber.size() <= 30)) &&
             (!('vehicleId' in data) || (data.vehicleId is string && data.vehicleId.size() <= 100)) &&
             (!('createdAt' in data) || (data.createdAt is string && data.createdAt.size() <= 100));
    }

    function isValidSentEmail(data) {
      return data.to is string && data.to.size() <= 100 &&
             data.name is string && data.name.size() <= 100 &&
             data.subject is string && data.subject.size() <= 200 &&
             data.type is string && (data.type == 'approve' || data.type == 'decline') &&
             data.dateSent is string && data.dateSent.size() <= 100 &&
             (!('comments' in data) || (data.comments is string && data.comments.size() <= 500) || data.comments == null) &&
             (!('vehicle' in data) || (data.vehicle is string && data.vehicle.size() <= 250)) &&
             (!('password' in data) || (data.password is string && data.password.size() <= 50));
    }

    function isValidIdLookup(data) {
      return data.email is string && data.email.size() <= 100;
    }

    // Match blocks
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if (isOwner(userId) || isAdmin()) && isValidUserProfile(incoming());
      allow update: if (
        (isOwner(userId) && isValidUserProfile(incoming()) && (
          incoming().role == existing().role &&
          incoming().email == existing().email &&
          incoming().diff(existing()).affectedKeys().hasOnly([
            'name', 'major', 'avatar', 'vehicle', 'walletBalance', 'tripsThisWeek',
            'carpoolRides', 'savedThisMonth', 'rating', 'ratingsCount',
            'todayEarnings', 'completedTripsCount', 'hoursOnline', 'status',
            'bankName', 'bankAccountNumber', 'bankAccountName'
          ])
        )) ||
        (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'ratingsCount'])) ||
        isAdmin()
      );
      allow delete: if isAdmin();

      // Nested collections
      match /transactions/{transactionId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if (isOwner(userId) || isAdmin()) && isValidTransaction(incoming());
        allow update, delete: if false; // Transactions ledger is write-once
      }

      match /notifications/{notificationId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if (isOwner(userId) || isDriver() || isAdmin() || isSignedIn()) && isValidNotification(incoming());
        allow update: if isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /reviews/{reviewId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isValidReview(incoming());
        allow update, delete: if isAdmin();
      }
    }

    match /rideRequests/{rideId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        incoming().passengerId == request.auth.uid ||
        (incoming().driverId != null && incoming().driverId == request.auth.uid) ||
        isAdmin()
      ) && isValidRideRequest(incoming());
      allow update: if isSignedIn() && (
        existing().passengerId == request.auth.uid ||
        existing().driverId == request.auth.uid ||
        incoming().driverId == request.auth.uid ||
        isAdmin()
      ) && isValidRideRequest(incoming());
      allow delete: if isSignedIn() && (existing().passengerId == request.auth.uid || existing().driverId == request.auth.uid || isAdmin());

      // Nested messages subcollection
      match /messages/{messageId} {
        allow read, create: if isSignedIn();
      }
    }

    match /pendingDrivers/{driverId} {
      allow read: if isOwner(driverId) || isAdmin();
      allow create: if isOwner(driverId) && isValidPendingDriver(incoming());
      allow update: if isAdmin() && isValidPendingDriver(incoming());
      allow delete: if isAdmin();
    }

    match /sent_emails/{emailId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin() && isValidSentEmail(incoming());
      allow delete: if isAdmin();
    }

    match /complaints/{complaintId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().passengerId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /schools/{schoolId} {
      allow read: if true;
      allow create, update: if isSignedIn() && isValidSchool(incoming());
      allow delete: if isAdmin();
    }

    match /idLookups/{lookupId} {
      allow get: if isValidId(lookupId);
      allow create: if true; // Create lookup during sign-up
      allow update, delete: if isAdmin() || (isSignedIn() && incoming().email == existing().email);
    }

    match /scheduledRideRequests/{scheduleId} {
      allow read, create, update, delete: if isSignedIn();
    }
  }
}
